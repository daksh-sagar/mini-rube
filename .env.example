# Copy to .env (scaffold.sh writes the COMPOSIO_* values for you).
# Required
COMPOSIO_API_KEY=your_composio_key
OPENROUTER_API_KEY=your_openrouter_key
GOOGLESUPER_AUTH_CONFIG_ID=ac_...
GITHUB_AUTH_CONFIG_ID=ac_...

# Optional model overrides (defaults in src/lib/llm.ts). AGENT (Haiku) is ~200k ctx;
# PLANNER/EXTRACTOR use deepseek-v4-flash (~1M ctx) only on bounded inputs for cost.
# For strict <500k adherence, set PLANNER/EXTRACTOR to deepseek/deepseek-chat (~128k).
# AGENT_MODEL=anthropic/claude-haiku-4.5
# PLANNER_MODEL=deepseek/deepseek-v4-flash
# EXTRACTOR_MODEL=deepseek/deepseek-v4-flash
# AGENT_MAX_TOKENS=2048
# JSON_MAX_TOKENS=1024

# Optional workflow tuning
# WORKFLOW_PAGE_SIZE=100
# WORKFLOW_SHEET_BATCH_SIZE=100
# WORKFLOW_CONCURRENCY=8
# WORKFLOW_USE_LLM_EXTRACTION=1
